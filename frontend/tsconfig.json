{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "outDir": "build",
    "allowJs": true,
    "rootDirs": ["src", "../e2e/mocks"],
    "isolatedModules": true,
    "noEmit": true,
    "declaration": false,
    "declarationMap": false
  },
  "include": ["src/**/*", "../e2e/mocks/cognitoClient.ts"],
  "exclude": ["node_modules", "build"]
}
